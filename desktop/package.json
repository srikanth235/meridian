{
  "name": "meridian-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell + React renderer for the Meridian orchestrator",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "build:renderer": "tsc -b && vite build",
    "build:mac": "electron-builder --mac --arm64",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
